# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/celengan"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-bot-token-from-@BotFather"
TELEGRAM_BOT_USERNAME="your_bot_username"

# Telegram Login Widget
NEXT_PUBLIC_TELEGRAM_BOT_NAME="your_bot_username"

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET="your-secret-at-least-32-characters-long-here"

# App URL (used for bot webhook)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "production" in prod
NODE_ENV="development"
